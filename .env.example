# Copy to .env.local for development. Never commit .env.local.
# Vite reads VITE_* and POS_BUILD_PROFILE only.

VITE_BACKEND_URL=http://localhost:8000
VITE_TENANT_SLUG=
VITE_RESTAURANT_ID=

# 'demo' (default, simulators only) or 'tenant' (production adapters; private builds only)
POS_BUILD_PROFILE=demo

# 'memory' (default, in-memory sync shim) or 'http' (POSTs to /api/pos/sync/push).
# Inferred to 'http' automatically when POS_BUILD_PROFILE=tenant + VITE_BACKEND_URL set.
VITE_SYNC_TRANSPORT_MODE=memory
